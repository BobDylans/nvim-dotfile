// 开发工作区 Layout
// 使用: zellij --layout dev
// 或: zellij attach dev --layout dev

layout {
    // 左侧大 pane：主工作区（编辑/主终端）
    pane size="65%" focus=true

    // 右侧上下两个小 pane
    pane size="35%" split_direction="horizontal" {
        pane name="terminal"
        pane name="monitor" command="btop"
    }
}
